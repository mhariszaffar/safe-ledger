# ── Server ────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── PostgreSQL ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=safeledger
DB_USER=postgres
DB_PASSWORD=your_postgres_password_here

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_in_production
JWT_EXPIRES_IN=7d

# ── Security ──────────────────────────────────────────────────────────────────
BCRYPT_ROUNDS=12

# ── Fraud Detection ───────────────────────────────────────────────────────────
# Max transactions per user per minute
MAX_TRANSACTIONS_PER_MINUTE=5
# Daily transfer limit in USD equivalent
DAILY_TRANSFER_LIMIT_USD=10000

# ── CORS ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173